# Sao chep file nay thanh .env va dien gia tri thuc
# Copy this file to .env and fill in real values

# ── BẮT BUỘC ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
TELEGRAM_TOKEN=
TELEGRAM_CHAT=

# ── TÙY CHỌN — Dữ liệu thị trường có cấu trúc ────────────────────────────────
# EIA Open Data (miễn phí, đăng ký tại https://www.eia.gov/opendata/)
# Dùng bởi: scripts/market_data.py → fetch_eia_inventory()
# Cung cấp: tồn kho dầu thô Mỹ hàng tuần, so sánh TB 5 năm
EIA_API_KEY=

# FRED API (miễn phí, đăng ký tại https://fred.stlouisfed.org/docs/api/fred/)
# Dùng bởi: scripts/market_data.py → fetch_fred_indicators()
# Cung cấp: DXY (Trade Weighted Dollar), lãi suất 10Y, Fed Funds Rate
FRED_API_KEY=
